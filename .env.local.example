# Enoki zkLogin — copy to .env.local and fill in. Both values are PUBLIC.
# Enoki Portal: https://portal.enoki.mystenlabs.com  (create a Public API key, enable testnet)
NEXT_PUBLIC_ENOKI_API_KEY=enoki_public_xxxxxxxxxxxxxxxx

# Google Cloud Console -> Credentials -> OAuth 2.0 Client ID (Web application)
#   Authorized JavaScript origins: http://localhost:3000  (+ your prod origin)
#   Authorized redirect URIs:      http://localhost:3000/auth/callback  (+ prod)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# HMAC secret for agent registration tokens (>=32 chars).
# Generate with: openssl rand -hex 32
AUTH_SECRET=
